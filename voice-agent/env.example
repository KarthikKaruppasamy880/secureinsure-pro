# Voice Agent Configuration

# JWT Configuration
JWT_JWKS_URL=https://your-idp.com/.well-known/jwks.json
ALLOWED_AUDIENCES=portal,backoffice
REQUIRED_SCOPES=voice:use,policy:read

# API Endpoints
API_BASE_POLICY=http://localhost:8082/api/v1/auth
API_BASE_VENDOR=http://localhost:8082/api/v1/auth
API_BASE_TASK=http://localhost:8082/api/v1/auth
TELEPHONY_BASE=

# STT/TTS Providers
STT_PROVIDER=local
TTS_PROVIDER=local

# Observability
OTEL_EXPORTER=jaeger
RATE_LIMIT_RPS=5
SESSION_TTL_SECONDS=600

# Development
NODE_ENV=development
PORT=8090
LOG_LEVEL=info