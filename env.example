# SecureInsure Pro Environment Configuration

# API Configuration
VITE_API_BASE_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000/ws

# Feature Flags
VITE_VOICE_ENABLED=true
VITE_ENABLE_FACE_DETECTION=true
VITE_ENABLE_CHATBOT=true
VITE_ENABLE_EXCEL_PARSING=true
VITE_APPDET_V2=1

# Development Flags
DEV_TEMPLATE_BYPASS=true
EXAMONE_MOCK=true

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://192.168.0.0/16,http://10.0.0.0/8

# Logging
LOG_LEVEL=info
VITE_DEBUG=true
VITE_LOG_LEVEL=info

# Application Info
VITE_APP_NAME=SecureInsure Pro
VITE_APP_VERSION=2.0.0

# Authentication
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRES_IN=24h

# External APIs
# EXAMONE_API_URL=https://api.examone.com
# EXAMONE_API_KEY=your-examone-api-key

# Cursor AI (for BugBot)
# CURSOR_API_KEY=your-cursor-api-key
