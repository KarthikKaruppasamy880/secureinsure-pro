# Backend Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
SERVER_PORT=8080
SERVER_HOST=localhost
SERVER_CONTEXT_PATH=/api
SERVER_SSL_ENABLED=false
SERVER_SSL_KEYSTORE_PATH=
SERVER_SSL_KEYSTORE_PASSWORD=

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=secureinsure_pro
DB_USERNAME=postgres
DB_PASSWORD=password
DB_SCHEMA=public
DB_POOL_SIZE=10
DB_MAX_POOL_SIZE=20

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_TIMEOUT=2000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=86400

# Security Configuration
BCRYPT_ROUNDS=12
SESSION_TIMEOUT=3600
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION=900

# External APIs
VOICE_PROVIDER=web
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Notification Services
NOTIFY_EMAIL_API=http://localhost:8080/api/v1/notifications/email
NOTIFY_SMS_API=http://localhost:8080/api/v1/notifications/sms
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@secureinsure.com

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/application.log
LOG_MAX_FILE_SIZE=10MB
LOG_MAX_FILES=5

# Monitoring
ENABLE_METRICS=true
ENABLE_HEALTH_CHECKS=true
ENABLE_ACTUATOR=true
METRICS_PORT=9090

# Feature Flags
ENABLE_VOICE_SEARCH=true
ENABLE_FACE_DETECTION=true
ENABLE_CHATBOT=true
ENABLE_EXCEL_PARSING=true
ENABLE_MOCK_MODE=false

# Development
DEBUG=true
PROFILE=dev
ENABLE_SWAGGER=true
ENABLE_H2_CONSOLE=false
