# Frontend Environment Configuration for SecureInsure Pro
# Copy this file to .env.local and fill in your values

# API Configuration
VITE_API_BASE_URL=http://localhost:8081
VITE_WS_URL=ws://localhost:8081/ws
VITE_API_VERSION=v1
VITE_USE_MOCKS=false

# Voice and Speech
VITE_VOICE_ENABLED=true
VITE_VOICE_DEBUG=false
VITE_VOICE_PROVIDER=web
VITE_AZURE_SPEECH_KEY=
VITE_AZURE_SPEECH_REGION=
VITE_TWILIO_ACCOUNT_SID=
VITE_TWILIO_AUTH_TOKEN=

# Notifications
VITE_NOTIFY_EMAIL_API=http://localhost:8081/api/v1/notifications/email
VITE_NOTIFY_SMS_API=http://localhost:8081/api/v1/notifications/sms

# Feature Flags
VITE_ENABLE_VOICE_SEARCH=true
VITE_ENABLE_FACE_DETECTION=true
VITE_ENABLE_CHATBOT=true
VITE_ENABLE_EXCEL_PARSING=true

# UI Configuration
VITE_THEME=light
VITE_LANGUAGE=en
VITE_TIMEZONE=UTC

# Development
VITE_DEBUG=false
VITE_LOG_LEVEL=info
VITE_ENABLE_HOT_RELOAD=true

# Security
VITE_ENABLE_HTTPS=false
VITE_SESSION_TIMEOUT=3600
VITE_MAX_LOGIN_ATTEMPTS=5

# Analytics (Optional)
VITE_GOOGLE_ANALYTICS_ID=
VITE_MIXPANEL_TOKEN=
