# Frontend Environment Configuration
# Copy this file to .env and fill in your values

# API Configuration
REACT_APP_API_BASE_URL=http://localhost:8080
REACT_APP_API_VERSION=v1
REACT_APP_USE_MOCKS=false

# Voice and Speech
REACT_APP_VOICE_PROVIDER=web
REACT_APP_AZURE_SPEECH_KEY=
REACT_APP_AZURE_SPEECH_REGION=
REACT_APP_TWILIO_ACCOUNT_SID=
REACT_APP_TWILIO_AUTH_TOKEN=

# Notifications
REACT_APP_NOTIFY_EMAIL_API=http://localhost:8080/api/v1/notifications/email
REACT_APP_NOTIFY_SMS_API=http://localhost:8080/api/v1/notifications/sms

# Feature Flags
REACT_APP_ENABLE_VOICE_SEARCH=true
REACT_APP_ENABLE_FACE_DETECTION=true
REACT_APP_ENABLE_CHATBOT=true
REACT_APP_ENABLE_EXCEL_PARSING=true

# UI Configuration
REACT_APP_THEME=light
REACT_APP_LANGUAGE=en
REACT_APP_TIMEZONE=UTC

# Development
REACT_APP_DEBUG=true
REACT_APP_LOG_LEVEL=info
REACT_APP_ENABLE_HOT_RELOAD=true

# Security
REACT_APP_ENABLE_HTTPS=false
REACT_APP_SESSION_TIMEOUT=3600
REACT_APP_MAX_LOGIN_ATTEMPTS=5

# Analytics (Optional)
REACT_APP_GOOGLE_ANALYTICS_ID=
REACT_APP_MIXPANEL_TOKEN=
