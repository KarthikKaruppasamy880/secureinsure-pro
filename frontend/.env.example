# API Configuration
REACT_APP_API_BASE_URL=http://localhost:8080
REACT_APP_WS_URL=ws://localhost:8080/ws

# Authentication
REACT_APP_AUTH_ENABLED=true
REACT_APP_AUTH_TOKEN_KEY=auth_token
REACT_APP_REFRESH_TOKEN_KEY=refresh_token

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_LOGGING=true

# External Services
REACT_APP_GOOGLE_ANALYTICS_ID=
REACT_APP_SENTRY_DSN=

# Application Settings
REACT_APP_DEFAULT_LANGUAGE=en
REACT_APP_DEFAULT_THEME=light

# Timeouts (in milliseconds)
REACT_APP_API_TIMEOUT=30000
REACT_APP_SESSION_TIMEOUT=3600000  # 1 hour

# Pagination
REACT_APP_DEFAULT_PAGE_SIZE=10
REACT_APP_MAX_PAGE_SIZE=100

# File Upload
REACT_APP_MAX_UPLOAD_SIZE=5242880  # 5MB
REACT_APP_ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf

# Security
REACT_APP_CSRF_COOKIE_NAME=XSRF-TOKEN
REACT_APP_SECURE_COOKIES=false

# Development Settings
REACT_APP_USE_MOCK_API=false
REACT_APP_SHOW_DEV_TOOLS=true
